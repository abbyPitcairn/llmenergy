#!/usr/bin/env bash
# bin/install — Set up the LLMEnergyConsumption project environment
set -eo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

echo "==> LLMEnergyConsumption — Install"
echo "    Project root: $REPO_ROOT"
echo ""

# ── 1. Python version check ───────────────────────────────────────────────────
REQUIRED_MAJOR=3
REQUIRED_MINOR=10

# Prefer the llmenergy conda env's Python, then fall back to whatever is on PATH
PYTHON=$(conda run -n llmenergy which python 2>/dev/null || command -v python3 || command -v python || true)

if [[ -z "$PYTHON" ]]; then
  echo "ERROR: Python 3 not found."
  echo "       Create the conda environment first:  conda create -n llmenergy python=3.11 -y"
  exit 1
fi

PY_VERSION=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
PY_MAJOR=$("$PYTHON" -c "import sys; print(sys.version_info.major)")
PY_MINOR=$("$PYTHON" -c "import sys; print(sys.version_info.minor)")

if [[ "$PY_MAJOR" -lt "$REQUIRED_MAJOR" ]] || \
   [[ "$PY_MAJOR" -eq "$REQUIRED_MAJOR" && "$PY_MINOR" -lt "$REQUIRED_MINOR" ]]; then
  echo "ERROR: Python ${REQUIRED_MAJOR}.${REQUIRED_MINOR}+ required (found ${PY_VERSION})."
  echo "       Create the conda environment first:  conda create -n llmenergy python=3.11 -y"
  exit 1
fi
echo "==> Python ${PY_VERSION} — OK"

# ── 2. Create virtual environment (if not already inside one) ─────────────────
if [[ -z "${VIRTUAL_ENV:-}" ]]; then
  if [[ ! -d ".venv" ]]; then
    echo "==> Creating virtual environment at .venv ..."
    # Use the conda-env Python so the venv inherits 3.11
    "$PYTHON" -m venv .venv
  else
    echo "==> Virtual environment .venv already exists — skipping creation."
  fi
  # shellcheck disable=SC1091
  source .venv/bin/activate
  echo "==> Activated .venv"
else
  echo "==> Already inside a virtual environment (${VIRTUAL_ENV}) — skipping creation."
fi

# ── 3. Upgrade pip ────────────────────────────────────────────────────────────
echo "==> Upgrading pip ..."
pip install --quiet --upgrade pip

# ── 4. Install core requirements ─────────────────────────────────────────────
echo "==> Installing requirements from requirements.txt ..."
pip install --quiet -r requirements.txt

# ── 5. Install optional power-tracking packages ──────────────────────────────
echo "==> Installing optional packages (pyRAPL, pynvml, psutil) ..."

pip install --quiet psutil || \
  echo "    [WARN] psutil install failed — CPU memory tracking will be disabled."

pip install --quiet pynvml || \
  echo "    [WARN] pynvml install failed — GPU power will fall back to nvidia-smi subprocess."

# pyRAPL is Linux-only (Intel RAPL interface)
if [[ "$(uname -s)" == "Linux" ]]; then
  pip install --quiet pyRAPL || \
    echo "    [WARN] pyRAPL install failed — CPU RAPL power tracking will be disabled."
else
  echo "    [INFO] Non-Linux system detected — skipping pyRAPL (not supported on $(uname -s))."
fi

# ── 6. Create required output directories ────────────────────────────────────
echo "==> Creating output directories ..."
mkdir -p Data Results

# ── 7. HuggingFace login check ────────────────────────────────────────────────
echo ""
echo "==> HuggingFace login"
echo "    LLaMA 3.1 is a gated model. You must accept the licence at:"
echo "    https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct"
echo "    and then authenticate with your HF token."
echo ""
echo "    Run:  huggingface-cli login"
echo "    Or set HF_TOKEN in bin/config before running bin/run."
echo ""

echo "==> Install complete."
echo "    To activate the environment in a new shell:"
echo "      source .venv/bin/activate"
echo "    Then run the experiment:"
echo "      bin/run"
